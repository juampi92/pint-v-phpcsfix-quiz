{
    "name": "juanpablo/php-cs-fixer-defaults",
    "description": "Export deterministic behavior differences between Laravel Pint and PHP-CS-Fixer defaults.",
    "type": "project",
    "require-dev": {
        "laravel/pint": "^1.0"
    },
    "scripts": {
        "export-differences": "php scripts/export-differences.php",
        "post-install-cmd": [
            "@export-differences"
        ],
        "post-update-cmd": [
            "@export-differences"
        ]
    }
}
