{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schema/pint-php-cs-fixer-differences.schema.json",
    "title": "Pint vs PHP-CS-Fixer Differences",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "preset",
        "output",
        "package_versions",
        "baseline",
        "counts",
        "differences",
        "limitations"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "const": 4
        },
        "preset": {
            "type": "string"
        },
        "output": {
            "type": "string"
        },
        "package_versions": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "laravel/pint",
                "friendsofphp/php-cs-fixer"
            ],
            "properties": {
                "laravel/pint": {
                    "type": "string"
                },
                "friendsofphp/php-cs-fixer": {
                    "type": "string"
                }
            }
        },
        "baseline": {
            "$ref": "#/$defs/baseline"
        },
        "counts": {
            "$ref": "#/$defs/counts"
        },
        "differences": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/difference"
            }
        },
        "limitations": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "$defs": {
        "jsonValue": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number"
                },
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/jsonValue"
                    }
                },
                {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/jsonValue"
                    }
                }
            ]
        },
        "baseline": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "strategy",
                "php_cs_fixer_defaults"
            ],
            "properties": {
                "strategy": {
                    "type": "string",
                    "const": "php_cs_fixer_raw_defaults_then_rule_defaults_for_pint_only_rules"
                },
                "php_cs_fixer_defaults": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/jsonValue"
                    }
                }
            }
        },
        "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "differences",
                "missing_from_pint",
                "different_configuration",
                "pint_differs_from_rule_default"
            ],
            "properties": {
                "differences": {
                    "type": "integer",
                    "minimum": 0
                },
                "missing_from_pint": {
                    "type": "integer",
                    "minimum": 0
                },
                "different_configuration": {
                    "type": "integer",
                    "minimum": 0
                },
                "pint_differs_from_rule_default": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "ruleState": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "enabled",
                "parameters"
            ],
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "parameters": {
                    "oneOf": [
                        {
                            "type": "null"
                        },
                        {
                            "$ref": "#/$defs/jsonValue"
                        }
                    ]
                }
            }
        },
        "comparison": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "case",
                "php_cs_fixer_side"
            ],
            "properties": {
                "case": {
                    "type": "string",
                    "enum": [
                        "php_cs_fixer_default_vs_pint",
                        "pint_vs_php_cs_fixer_rule_default"
                    ]
                },
                "php_cs_fixer_side": {
                    "type": "string",
                    "enum": [
                        "raw_default",
                        "rule_default"
                    ]
                }
            }
        },
        "phpCsFixerStates": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "comparison",
                "raw_default",
                "rule_default"
            ],
            "properties": {
                "comparison": {
                    "$ref": "#/$defs/ruleState"
                },
                "raw_default": {
                    "$ref": "#/$defs/ruleState"
                },
                "rule_default": {
                    "$ref": "#/$defs/ruleState"
                }
            }
        },
        "phpCsFixerRuleSetMembership": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "direct",
                "inherited"
            ],
            "properties": {
                "direct": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "inherited": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "fixer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "class",
                "configurable",
                "path",
                "github"
            ],
            "properties": {
                "class": {
                    "type": "string"
                },
                "configurable": {
                    "type": "boolean"
                },
                "path": {
                    "type": "string"
                },
                "github": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/githubReference"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            }
        },
        "githubReference": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "url",
                "path",
                "start_line",
                "end_line"
            ],
            "properties": {
                "url": {
                    "type": "string"
                },
                "path": {
                    "type": "string"
                },
                "start_line": {
                    "type": "integer",
                    "minimum": 1
                },
                "end_line": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "phpCsFixerRulesetReferences": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "definition",
                "rule"
            ],
            "properties": {
                "definition": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/githubReference"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "rule": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/githubReference"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            }
        },
        "phpCsFixerRuleset": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "description",
                "risky",
                "declared_directly",
                "state",
                "references"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "risky": {
                    "type": "boolean"
                },
                "declared_directly": {
                    "type": "boolean"
                },
                "state": {
                    "$ref": "#/$defs/ruleState"
                },
                "references": {
                    "$ref": "#/$defs/phpCsFixerRulesetReferences"
                }
            }
        },
        "references": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "php_cs_fixer",
                "pint"
            ],
            "properties": {
                "php_cs_fixer": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/githubReference"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "pint": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/githubReference"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            }
        },
        "difference": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "rule",
                "category",
                "comparison",
                "pint",
                "php_cs_fixer",
                "php_cs_fixer_rule_set_membership",
                "php_cs_fixer_rulesets",
                "fixer",
                "references"
            ],
            "properties": {
                "rule": {
                    "type": "string"
                },
                "category": {
                    "type": "string",
                    "enum": [
                        "missing_from_pint",
                        "different_configuration",
                        "pint_differs_from_rule_default"
                    ]
                },
                "comparison": {
                    "$ref": "#/$defs/comparison"
                },
                "pint": {
                    "$ref": "#/$defs/ruleState"
                },
                "php_cs_fixer": {
                    "$ref": "#/$defs/phpCsFixerStates"
                },
                "php_cs_fixer_rule_set_membership": {
                    "$ref": "#/$defs/phpCsFixerRuleSetMembership"
                },
                "php_cs_fixer_rulesets": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/phpCsFixerRuleset"
                    }
                },
                "fixer": {
                    "$ref": "#/$defs/fixer"
                },
                "references": {
                    "$ref": "#/$defs/references"
                }
            }
        }
    }
}
